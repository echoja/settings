{
  "$schema": "./jobs.schema.json",
  "jobs": [
    {
      "label": "com.echoja.settings-pull",
      "description": "Daily auto-pull of settings repo",
      "script": "scripts/auto-pull.sh",
      "schedule": {
        "hour": 9,
        "minute": 0
      },
      "environment": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "label": "com.echoja.brew-upgrade-claude",
      "description": "Daily auto-upgrade of Claude CLI via Homebrew",
      "script": "scripts/brew-upgrade-claude.sh",
      "schedule": {
        "hour": 10,
        "minute": 0
      },
      "environment": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "label": "com.echoja.omz-update",
      "description": "Daily auto-update of Oh My Zsh",
      "script": "scripts/omz-update.sh",
      "schedule": {
        "hour": 10,
        "minute": 30
      },
      "environment": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  ]
}
